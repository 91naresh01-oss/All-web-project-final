                            ["<b>Preposition of Place</b>", "स्थान के लिए", "in (room), on (table), at (home)"],
                            ["<b>Preposition of Direction</b>", "दिशा के लिए", "to, from, into, towards, through"],
                            ["<b>Preposition of Agent</b>", "कर्ता के लिए", "by (Passive Voice में)"],
                            ["<b>Preposition of Instrument</b>", "साधन के लिए", "with (pen), by (bus)"]
