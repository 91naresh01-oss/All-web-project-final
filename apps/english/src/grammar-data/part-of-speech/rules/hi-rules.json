                            ["<b>Helping Verb</b>", "Main Verb की मदद करता है", "is, am, are, was, were, has, have, do, does, did"],
                            ["<b>Modal Verb</b>", "Ability/Permission/Possibility", "can, could, may, might, shall, should, will, would, must"],
                            ["<b>Linking Verb</b>", "Subject को Complement से जोड़ता है", "is, am, are, seem, appear, become, feel"]
