                            ["<b>Personal Pronoun</b>", "पुरुषवाचक", "I, We, You, He, She, It, They"],
                            ["<b>Possessive Pronoun</b>", "अधिकारवाचक", "Mine, Ours, Yours, His, Hers, Theirs"],
                            ["<b>Reflexive Pronoun</b>", "निजवाचक", "Myself, Ourselves, Yourself, Himself, Herself"],
                            ["<b>Demonstrative Pronoun</b>", "संकेतवाचक", "This, That, These, Those"],
                            ["<b>Interrogative Pronoun</b>", "प्रश्नवाचक", "Who, Whom, Which, What, Whose"],
                            ["<b>Relative Pronoun</b>", "संबंधवाचक", "Who, Which, That, Whom, Whose"]
                        ]
                    }
                },
                {
                    "type": "table",
                    "content": {
                        "title": "🔄 Personal Pronoun Forms",
                        "headers": ["Person", "Subject", "Object", "Possessive"],
                        "rows": [
                            ["1st Singular", "<b>I</b>", "me", "my/mine"],
                            ["1st Plural", "<b>We</b>", "us", "our/ours"],
                            ["2nd", "<b>You</b>", "you", "your/yours"],
                            ["3rd Singular (M)", "<b>He</b>", "him", "his"],
                            ["3rd Singular (F)", "<b>She</b>", "her", "her/hers"],
                            ["3rd Singular (N)", "<b>It</b>", "it", "its"],
                            ["3rd Plural", "<b>They</b>", "them", "their/theirs"]
