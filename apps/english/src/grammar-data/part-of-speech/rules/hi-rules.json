                    "type": "table",
                    "content": {
                        "title": "🔑 In / On / At - Quick Rules",
                        "headers": ["Preposition", "Time", "Place"],
                        "rows": [
                            ["<b>In</b>", "Month, Year, Season<br>(in January, in 2024)", "Big places - City, Country<br>(in India, in Mumbai)"],
                            ["<b>On</b>", "Day, Date<br>(on Monday, on 5th Jan)", "Surface - floor, wall<br>(on the table, on the road)"],
                            ["<b>At</b>", "Specific Time<br>(at 5 o'clock, at noon)", "Specific Point<br>(at home, at the bus stop)"]
                        ]
