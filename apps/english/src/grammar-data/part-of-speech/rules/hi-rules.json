                            ["<b>Adjective of Quality</b>", "गुणवाचक", "good, bad, beautiful, tall, honest"],
                            ["<b>Adjective of Quantity</b>", "परिमाणवाचक", "some, much, little, enough, all"],
                            ["<b>Adjective of Number</b>", "संख्यावाचक", "one, two, first, second, many, few"],
                            ["<b>Demonstrative Adjective</b>", "संकेतवाचक", "this, that, these, those"],
                            ["<b>Possessive Adjective</b>", "अधिकारवाचक", "my, your, his, her, our, their"],
                            ["<b>Interrogative Adjective</b>", "प्रश्नवाचक", "which, what, whose"]
