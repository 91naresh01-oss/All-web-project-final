              ["<b>Moreover</b>", "इसके अलावा", "He is smart; <b>moreover</b>, he is kind.", "वह होशियार है; <b>इसके अलावा</b> दयालु है।"],
              ["<b>Furthermore</b>", "इसके अलावा", "It's cheap; <b>furthermore</b>, it's good.", "यह सस्ता है; <b>इसके अलावा</b> अच्छा है।"],
              ["<b>Nevertheless</b>", "फिर भी", "He's tired; <b>nevertheless</b>, he works.", "वह थका है; <b>फिर भी</b> काम करता है।"],
              ["<b>Otherwise</b>", "नहीं तो", "Study; <b>otherwise</b> you'll fail.", "पढ़ो; <b>नहीं तो</b> फेल होगे।"],
              ["<b>Meanwhile</b>", "इस बीच", "Wait; <b>meanwhile</b>, I'll check.", "रुको; <b>इस बीच</b> मैं देखता हूँ।"],
              ["<b>Instead</b>", "के बजाय", "Don't cry; <b>instead</b>, try again.", "मत रोओ; <b>के बजाय</b> फिर कोशिश करो।"]
