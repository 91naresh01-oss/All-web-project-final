{
  "name": "edu-platform",
  "private": true,
  "scripts": {
    "dev": "cross-env NODE_OPTIONS=\"--max-old-space-size=2048\" turbo dev --concurrency=5",
    "build": "turbo build",
    "lint": "turbo lint",
    "clean": "turbo clean && rimraf .turbo \"apps/*/.next\"",
    "dev:hub": "cross-env NODE_OPTIONS=\"--max-old-space-size=2048\" turbo dev --filter=@edu/hub --concurrency=2",
    "dev:maths": "cross-env NODE_OPTIONS=\"--max-old-space-size=2048\" turbo dev --filter=@edu/maths --concurrency=2",
    "dev:english": "cross-env NODE_OPTIONS=\"--max-old-space-size=2048\" turbo dev --filter=@edu/english --concurrency=2",
    "dev:gujarati": "cross-env NODE_OPTIONS=\"--max-old-space-size=2048\" turbo dev --filter=@edu/gujarati --concurrency=2"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "cross-env": "^10.1.0",
    "rimraf": "^6.1.3",
    "turbo": "latest"
  },
  "packageManager": "pnpm@10.33.2"
}
